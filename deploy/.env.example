# ThinkNEO Gateway — Self-hosted configuration
# Copy to .env and customize

# Master API key (accepts any requests with this key)
THINKNEO_API_KEY=

# Additional API keys (comma-separated)
THINKNEO_MCP_API_KEYS=

# Database password
MCP_DB_PASSWORD=thinkneo_local_dev

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://claude.ai

# OpenTelemetry (set to true to enable)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Log redaction (default: true)
LOG_REDACTION=true
