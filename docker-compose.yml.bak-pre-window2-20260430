services:
  redis:
    image: redis:7-alpine
    container_name: thinkneo-mcp-redis
    user: "999:999"
    command:
      - redis-server
      - --requirepass
      - "${MCP_REDIS_PASSWORD}"
      - --appendonly
      - "yes"
      - --maxmemory
      - 128mb
      - --maxmemory-policy
      - allkeys-lru
    volumes:
      - mcp_redis_data:/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${MCP_REDIS_PASSWORD}", "ping"]
      interval: 10s
      timeout: 3s
      retries: 5
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 256m
        reservations:
          cpus: "0.1"
          memory: 32m
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  thinkneo-mcp:
    build:
      context: .
      dockerfile: Dockerfile
    image: thinkneo-mcp-server:latest
    container_name: thinkneo-mcp-server
    user: "999:988"
    restart: unless-stopped
    ports:
      - "127.0.0.1:8081:8081"
      - "100.75.242.28:8081:8081"
    volumes:
      - /home/openclaw/.claude/projects/-opt/memory:/app/memory:rw
    env_file:
      - .env
    environment:
      HOST: "0.0.0.0"
      PORT: "8081"
      MCP_DB_HOST: "172.17.0.1"
      MCP_DB_PORT: "5432"
      MCP_DB_NAME: "thinkneo_mcp"
      MCP_DB_USER: "mcp_user"
      MCP_DB_PASSWORD: "${MCP_DB_PASSWORD}"
      MCP_REDIS_URL: "redis://:${MCP_REDIS_PASSWORD}@redis:6379/0"
    depends_on:
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "python3", "-c",
        "import urllib.request; req = urllib.request.Request('http://127.0.0.1:8081/mcp', data=b'{\"jsonrpc\":\"2.0\",\"method\":\"initialize\",\"id\":1,\"params\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{},\"clientInfo\":{\"name\":\"healthcheck\",\"version\":\"1.0\"}}}', headers={'Content-Type': 'application/json', 'Accept': 'application/json, text/event-stream'}, method='POST'); urllib.request.urlopen(req, timeout=4)"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "5"

volumes:
  mcp_redis_data: {}
