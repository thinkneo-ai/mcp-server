# ThinkNEO MCP Server — Environment Variables
# Copy to .env and fill in your values.

# Server
HOST=0.0.0.0
PORT=8081
DEBUG=false
LOG_LEVEL=INFO
WORKERS=2

# Public URL (used in error messages and docs)
PUBLIC_URL=https://mcp.thinkneo.ai

# Authentication — comma-separated API keys that clients must use as Bearer tokens.
# Leave empty to run in open demo mode (any token accepted).
THINKNEO_MCP_API_KEYS=
# Single master key — always valid (e.g. ThinkNEO internal tools)
THINKNEO_API_KEY=

# Optional: forward demo booking requests to a webhook (Slack, n8n, Zapier, etc.)
DEMO_WEBHOOK_URL=
DEMO_EMAIL=hello@thinkneo.ai

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://copilot.microsoft.com,http://localhost:3000

# Optional: internal ThinkNEO governance API (leave empty to use embedded logic)
THINKNEO_API_BASE_URL=
